<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup  xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Client.Pagemodel.Popups"
             xmlns:models="clr-namespace:Domain.Entities;assembly=Domain"
             x:Class="Client.Popups.EliminarPopup"
             x:DataType="vm:EliminarPopupPagemodel"
             x:TypeArguments="models:Confirmar"
             Background="#E8E3D3">
             
    <VerticalStackLayout>
        <Label Text="{Binding Mensaje}" HorizontalOptions="Center"/>
        <Button Text="Eliminar" Command="{Binding SaveCommand}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold" Margin="0,0,0,5"/>
        <Button Text="Cancelar" Command="{Binding CancelCommand}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold"/>
    </VerticalStackLayout>
</toolkit:Popup>