<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Client.Pagemodel.Inventarios"
             xmlns:domain="clr-namespace:Domain.Entities;assembly=Domain"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="Client.Pages.Inventarios.EspeciePage"
             x:DataType="vm:EspeciePagemodel"
             x:Name="RootPage"
             >
    <ScrollView>
    <VerticalStackLayout BackgroundColor="#3AA6A0">
            <Border StrokeShape="RoundRectangle 50" MaximumWidthRequest="750" Stroke="#14453D" StrokeThickness="3" Margin="0,200" BackgroundColor="#E8E3D3">
                <StackLayout>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding volverCommand}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold" Margin="15" mi:MauiIcon.Value="{mi:Fluent Icon=ArrowLeft20}"/>
                        <Button Grid.Column="2" Command="{Binding abrirPopupAñadirCommand}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold" Margin="15" mi:MauiIcon.Value="{mi:Fluent Icon=Add20}"/>
                    </Grid>
                    <CollectionView ItemsSource="{Binding Especies}">
                        <CollectionView.EmptyView>
                            <Label Text="No hay especies registradas" 
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            TextColor="Black"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="domain:Especie">
                                <Border BackgroundColor="#C9C7C2" Stroke="#14453D" StrokeThickness="3" BindingContext="{Binding}">
                                    <StackLayout>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.abrirPopupEliminarCommand}" CommandParameter="{Binding .}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold" Margin="0,0,250,0" Grid.Column="0" Grid.Row="0" mi:MauiIcon.Value="{mi:Fluent Icon=Delete20}"/>
                                            <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.abrirPopupModificarCommand}" CommandParameter="{Binding .}" BackgroundColor="#D9E2D0" TextColor="#14453D" BorderColor="#14453D" BorderWidth="3" FontAttributes="Bold" Margin="250,0,0,0" Grid.Column="1" Grid.Row="0" mi:MauiIcon.Value="{mi:Fluent Icon=Settings20}"/>
                                            <Label Text="Nombre:" FontAttributes="Bold" Grid.Column="0" Grid.Row="1" HorizontalTextAlignment="End"/>
                                            <Label Text="{Binding nombre}" FontAttributes="Bold" Grid.Column="1" Grid.Row="1"/>
                                            <Label Text="Nombre Cientifico:" FontAttributes="Bold" Grid.Column="0" Grid.Row="2" HorizontalTextAlignment="End"/>
                                            <Label Text="{Binding nombreCientifico}" FontAttributes="Bold" Grid.Column="1" Grid.Row="2" />
                                            <Label Text="Tipo de Alimentacion:" FontAttributes="Bold" Grid.Column="0" Grid.Row="3" HorizontalTextAlignment="End"/>
                                            <Label Text="{Binding tipoAlimentacion}" FontAttributes="Bold" Grid.Column="1" Grid.Row="3" Margin="0,0,0,20"/>
                                        </Grid>
                                    </StackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>